# ElevenLabs neural voice (optional). Without ELEVENLABS_API_KEY, R.A.M.B.O
# falls back to the browser's built-in speech voice.
ELEVENLABS_API_KEY=
# Voice to speak with (defaults to this if unset).
ELEVENLABS_VOICE_ID=jCv6DMvHrCxAiWzQcSEl
# TTS model (low-latency default).
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Echo outbound email (optional). Without these, Echo reports OFFLINE and won't
# send. For Gmail use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ECHO_DEFAULT_TO=

# Recurring morning brief (optional; defaults shown). Sent daily on screen + email.
MORNING_BRIEF_TIME=07:00
MORNING_BRIEF_TZ=America/Detroit

# Voyage AI embeddings (optional). Powers the semantic router pre-filter and
# Keeper's knowledge graph. Without VOYAGE_API_KEY, both fall back to keyword
# matching. 200M free tokens/account — effectively free at R.A.M.B.O's volume.
# NOTE: don't change RAMBO_EMBED_MODEL after Keeper is populated (stored vectors
# live in one model's space; switching breaks recall until re-embedded).
VOYAGE_API_KEY=
RAMBO_EMBED_MODEL=voyage-4-lite
RAMBO_ROUTE_TOPK=6
RAMBO_TOPIC_THRESHOLD=0.6
VOYAGE_FREE_TOKENS=200000000
VOYAGE_CREDIT_USD=20

# Spotify (optional) — in-app player via the Web Playback SDK (requires Premium).
# Create an app at https://developer.spotify.com/dashboard, add the redirect URI
# below (must be the loopback IP, not localhost), and enable Web API + Web
# Playback SDK. Then paste the Client ID / Secret here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/spotify/callback

# MLB betting ingestion layer (optional). Paid Apify actors are used ONLY for odds
# + DK Pick6 props; roster/schedule/stats come free from statsapi.mlb.com (no key).
APIFY_TOKEN=
# Isolated SQLite DB for ingested MLB data + the migrations directory.
RAMBO_DB_PATH=data/mlb_ingest.db
RAMBO_MIGRATIONS_DIR=db/migrations

# GitHub push (optional) — lets RAMBO commit + push its OWN repo, gated behind
# your per-push approval (dock or voice: "approve the push"). Use a FINE-GRAINED
# personal access token scoped to ONLY this repo with Contents: read/write.
# Never force-pushes; commits are secret-scanned first. Leave blank to disable.
RAMBO_GITHUB_TOKEN=
